<script>
  // Chart bars
  const bars = document.getElementById('chart-bars');
  const vals = [28,36,42,55,72,88];
  const colors = ['rgba(124,106,255,.25)','rgba(124,106,255,.35)','rgba(124,106,255,.45)','rgba(124,106,255,.6)','rgba(124,106,255,.8)','rgba(124,106,255,1)'];
  vals.forEach((v,i) => {
    const b = document.createElement('div');
    b.className = 'bar';
    b.style.cssText = `height:${v}%;background:${colors[i]};`;
    bars.appendChild(b);
  });

  // Scroll fade-in
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
  }, {threshold:0.12});
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  // Feature items toggle
  document.querySelectorAll('.feature-item').forEach(item => {
    item.addEventListener('click', () => {
      document.querySelectorAll('.feature-item').forEach(i => i.classList.remove('active'));
      item.classList.add('active');
    });
  });
</script>
